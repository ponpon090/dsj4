; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows for simple changes.
; *** DO NOT MANUALLY EDIT THIS FILE ***

config_version=5

[application]

config/name="DSJ4 - Deluxe Ski Jump 4"
config/description="A ski jumping simulator"
run/main_scene="res://scenes/menu/MainMenu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[physics]

common/physics_ticks_per_second=60

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.2, 0.3, 0.5, 1)
